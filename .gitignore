# === MEDICAL DATA — MIMIC PhysioNet DUA (NEVER COMMIT) ===
# Parquet cohort tables contain patient identifiers (subject_id, study_id,
# hadm_id, stay_id) derived from MIMIC. Committing to a public repo is a DUA violation.
artifacts/manifests/
artifacts/tables/

# Patient-level predictions (subject_id + model probability scores)
artifacts/models/**/test_predictions*.csv
artifacts/models/**/val_predictions*.csv
artifacts/models/**/test_predictions_with_ids.csv

# SHAP values CSV (contains subject_id, study_id columns)
artifacts/evaluation/shap/shap_values.csv

# Non-ED generalization predictions (contains subject_id, study_id columns)
artifacts/evaluation/nonED_generalization_image_predictions.csv

# Root-level false-positive analysis (contains patient IDs)
fp_top50.csv

# === LARGE MODEL BINARIES — Host on Zenodo / HuggingFace Hub ===
# *.pt / *.pth already covered above; this adds sklearn/XGBoost serialized models
artifacts/models/**/*.joblib
artifacts/models/**/*.sav
artifacts/models/**/checkpoints/

